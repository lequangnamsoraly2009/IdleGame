{
  "rules": {
    "pages": {
      ".read": true,
      ".write": true
    },
    "standaloneReupItems": {
      ".read": true,
      ".write": true
    },
    "commissionGoalData": {
      ".read": true,
      ".write": true
    },
    "shared": {
      ".read": true,
      ".write": true
    },
    "sharedDBTracking": {
      ".read": true,
      ".write": true
    },
    "game": {
      "wordwithsoraly": {
        ".read": "auth != null",
        ".write": "auth != null",
        "rooms": {
          "$roomCode": {
            ".validate": "$roomCode.matches(/^[A-Za-z0-9]{6}$/)"
          }
        }
      },
      "soralytaketwo": {
        ".read": "auth != null",
        ".write": "auth != null",
        "rooms": {
          "$roomCode": {
            ".read": "auth != null",
            ".write": "auth != null && $roomCode.matches(/^[A-Za-z0-9]{6}$/)",
            "hostUid": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160"
            },
            "progress": {
              "levelIndex": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 128"
              }
            },
            "puzzle": {
              "vaultOpen": {
                ".validate": "newData.isBoolean()"
              },
              "doorLatchUntil": {
                ".validate": "!newData.exists() || newData.val() == null || (newData.isNumber() && newData.val() > 0)"
              }
            },
            "players": {
              "$role": {
                ".validate": "($role === 'host' || $role === 'guest') && newData.hasChildren(['x', 'y', 'vx', 'vy']) && newData.child('x').isNumber() && newData.child('y').isNumber() && newData.child('vx').isNumber() && newData.child('vy').isNumber()"
              }
            }
          }
        }
      }
    },
    "keoDau": {
      "admins": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      },
      "brackets": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "users": {
        ".read": "auth != null",
        ".indexOn": ["dauBalance"],
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && ((auth.uid === $uid && (!data.exists() || newData.child('totalPoints').val() === data.child('totalPoints').val())) || root.child('keoDau/admins').child(auth.uid).val() === true)",
          "uid": {
            ".validate": "newData.val() === $uid"
          },
          "displayName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "photoURL": {
            ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
          },
          "email": {
            ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
          },
          "totalPoints": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
          },
          "dauBalance": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
          },
          "createdAt": {
            ".validate": "newData.isString() || newData.isNumber()"
          }
        }
      },
      "groups": {
        ".indexOn": ["inviteCode"],
        "$groupId": {
          ".read": "auth != null && data.child('memberIds').child(auth.uid).val() === true",
          ".write": "auth != null && ((!data.exists() && newData.child('createdBy').val() === auth.uid && newData.child('memberIds').child(auth.uid).val() === true) || (data.exists() && data.child('memberIds').child(auth.uid).val() === true))",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 60"
          },
          "inviteCode": {
            ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9]{6}$/)"
          },
          "createdBy": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160"
          },
          "defaultDauBalance": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
          },
          "createdAt": {
            ".validate": "newData.isString() || newData.isNumber()"
          },
          "memberIds": {
            "$memberId": {
              ".validate": "newData.isBoolean() && newData.val() === true"
            }
          },
          "members": {
            "$memberId": {
              ".read": "auth != null && root.child('keoDau/groups').child($groupId).child('memberIds').child(auth.uid).val() === true",
              ".write": "auth != null && auth.uid === $memberId && !data.exists() && root.child('keoDau/groups').child($groupId).child('memberIds').child(auth.uid).val() === true",
              "userId": {
                ".validate": "newData.val() === $memberId"
              },
              "displayName": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
              },
              "photoURL": {
                ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
              },
              "dauBalance": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
              },
              "points": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
              }
            }
          }
        }
      },
      "userGroups": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$groupId": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.val() === true"
          }
        }
      },
      "groupInviteCodes": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.isString() && newData.val().length > 0"
        }
      },
      "matches": {
        ".read": true,
        ".write": "auth != null && root.child('keoDau/admins').child(auth.uid).val() === true",
        ".indexOn": ["status", "kickoff"],
        "$matchId": {
          "externalId": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "homeTeam": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "awayTeam": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "kickoff": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "status": {
            ".validate": "newData.val().matches(/^(scheduled|live|finished|postponed)$/)"
          },
          "homeScore": {
            ".validate": "!newData.exists() || newData.val() == null || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 99)"
          },
          "awayScore": {
            ".validate": "!newData.exists() || newData.val() == null || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 99)"
          },
          "settled": {
            ".validate": "newData.isBoolean()"
          }
        }
      },
      "matchOdds": {
        ".read": true,
        ".write": "auth != null && root.child('keoDau/admins').child(auth.uid).val() === true",
        "$matchId": {
          "matchId": {
            ".validate": "newData.val() === $matchId"
          },
          "source": {
            ".validate": "newData.val() === 'the-odds-api'"
          },
          "syncedAt": {
            ".validate": "newData.isString() && newData.val().length > 0"
          }
        }
      },
      "keos": {
        ".read": true,
        ".write": "auth != null",
        ".indexOn": ["slug", "matchId", "status"],
        "$keoId": {
          ".write": "auth != null && ((!data.exists() && newData.child('createdBy').val() === auth.uid && (root.child('keoDau/matches').child(newData.child('matchId').val()).child('status').val() === 'scheduled' || root.child('keoDau/matches').child(newData.child('matchId').val()).child('status').val() === 'live')) || (data.exists() && data.child('status').val() === 'open' && (root.child('keoDau/matches').child(data.child('matchId').val()).child('status').val() === 'scheduled' || root.child('keoDau/matches').child(data.child('matchId').val()).child('status').val() === 'live') && auth.uid !== data.child('createdBy').val() && !data.child('participants').child(auth.uid).exists()) || (data.exists() && !newData.exists() && data.child('status').val() === 'open' && data.child('createdBy').val() === auth.uid && (!data.hasChild('participants') || !data.child('participants').hasChildren())) || (data.exists() && (data.child('status').val() === 'open' || data.child('status').val() === 'locked') && newData.child('status').val() === 'settled' && root.child('keoDau/admins').child(auth.uid).val() === true))",
          "slug": {
            ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9]{4,16}$/)"
          },
          "title": {
            ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 120"
          },
          "matchId": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "groupId": {
            ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
          },
          "createdBy": {
            ".validate": "!data.exists() ? newData.val() === auth.uid : newData.val() === data.val()"
          },
          "type": {
            ".validate": "newData.val().matches(/^(winner|score|handicap|over_under)$/)"
          },
          "status": {
            ".validate": "newData.val().matches(/^(open|locked|settled)$/)"
          },
          "minDau": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 100000"
          },
          "maxDau": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 100000 && newData.val() >= newData.parent().child('minDau').val()"
          },
          "allowGuestVote": {
            ".validate": "newData.val() === false"
          },
          "creatorName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "isHouseKeo": {
            ".validate": "newData.isBoolean()"
          },
          "creatorPick": {
            ".validate": "!newData.exists() || (newData.hasChildren(['optionId', 'dauAmount', 'userId', 'displayName']) && (!data.exists() || (newData.child('optionId').val() === data.child('optionId').val() && newData.child('dauAmount').val() === data.child('dauAmount').val() && newData.child('userId').val() === data.child('userId').val())))"
          },
          "housePick": {
            ".validate": "!newData.exists() || (newData.hasChildren(['userId', 'displayName']) && ((!data.exists() && newData.child('userId').val() === auth.uid) || (data.exists() && newData.child('userId').val() === data.child('userId').val())) && (!newData.hasChild('dauAmount') || (newData.child('dauAmount').isNumber() && newData.child('dauAmount').val() >= 0)))"
          },
          "opponentPick": {
            ".validate": "!newData.exists() || (newData.hasChildren(['optionId', 'dauAmount', 'userId', 'displayName']) && ((!data.exists() && newData.child('userId').val() === auth.uid) || (data.exists() && newData.child('userId').val() === data.child('userId').val())))"
          },
          "participants": {
            "$participantId": {
              ".write": "auth != null && root.child('keoDau/keos').child($keoId).child('status').val() === 'open' && (root.child('keoDau/matches').child(root.child('keoDau/keos').child($keoId).child('matchId').val()).child('status').val() === 'scheduled' || root.child('keoDau/matches').child(root.child('keoDau/keos').child($keoId).child('matchId').val()).child('status').val() === 'live') && auth.uid !== root.child('keoDau/keos').child($keoId).child('createdBy').val() && (!data.exists() || data.child('userId').val() === auth.uid) && newData.child('userId').val() === auth.uid",
              ".validate": "newData.hasChildren(['optionId', 'dauAmount', 'userId', 'displayName']) && newData.child('userId').val() === auth.uid && newData.child('dauAmount').isNumber() && newData.child('dauAmount').val() >= root.child('keoDau/keos').child($keoId).child('minDau').val() && newData.child('dauAmount').val() <= 100000"
            }
          },
          "createdAt": {
            ".validate": "newData.isString() || newData.isNumber()"
          },
          "options": {
            "$optionId": {
              ".write": "auth != null && (root.child('keoDau/keos').child($keoId).child('createdBy').val() === auth.uid || (root.child('keoDau/keos').child($keoId).child('status').val() === 'open' && auth.uid !== root.child('keoDau/keos').child($keoId).child('createdBy').val()))",
              ".validate": "newData.hasChildren(['id', 'label', 'voteCount', 'totalDau'])",
              "id": {
                ".validate": "newData.isString() && newData.val().length > 0"
              },
              "label": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
              },
              "voteCount": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
              },
              "totalDau": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000000"
              },
              "oddsPrice": {
                ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 1000)"
              }
            }
          }
        }
      },
      "predictions": {
        ".indexOn": ["matchId", "keoId", "userId"],
        "$predictionId": {
          ".read": "auth != null && (data.child('userId').val() === auth.uid || (data.child('groupId').exists() && data.child('groupId').val() != null && root.child('keoDau/groups').child(data.child('groupId').val()).child('memberIds').child(auth.uid).val() === true))",
          ".write": "false",
          "keoId": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "userId": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "optionId": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "dauAmount": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 100"
          },
          "groupId": {
            ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
          }
        }
      },
      "guestVotes": {
        ".read": false,
        ".write": false
      },
      "leaderboards": {
        "$boardId": {
          ".read": true,
          ".write": false,
          "groupId": {
            ".validate": "!newData.exists() || newData.val() == null || newData.isString()"
          },
          "season": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "rankings": {
            ".read": true,
            "$rank": {
              ".validate": "newData.hasChildren(['userId', 'points', 'rank'])",
              "userId": {
                ".validate": "newData.isString() && newData.val().length > 0"
              },
              "displayName": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
              },
              "points": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              },
              "rank": {
                ".validate": "newData.isNumber() && newData.val() >= 1"
              },
              "correctScores": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              },
              "correctWinners": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              }
            }
          }
        }
      },
      "notifications": {
        "$uid": {
          "$notificationId": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "false",
            "title": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
            },
            "body": {
              ".validate": "newData.isString() && newData.val().length <= 300"
            },
            "read": {
              ".validate": "newData.isBoolean()"
            },
            "createdAt": {
              ".validate": "newData.isString() || newData.isNumber()"
            }
          }
        }
      },
      "idleRpg": {
        "users": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
